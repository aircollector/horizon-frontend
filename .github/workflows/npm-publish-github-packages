name: Node.js Package

on:
  push:
    branches:
      - main
jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code #1
        uses: actions/checkout@v2

      - name: Set up Node 20 #2
        uses: actions/setup-node@v3
        with:
          node-version: 20

      - name: Install dependencies #3
        run: npm install

      - name: Build React app #4
        run: npm run build

      - name: Archive the build folder #5
        run: zip -r deploy.zip build package.json package-lock.json .ebextensions

      - name: Get current time #6
        uses: josStorer/get-current-time@v2.0.2
        id: current-time
        with:
          format: YYYY-MM-DDTHH-mm-ss
          utcOffset: '+09:00'

      - name: Beanstalk Deploy #7
        uses: einaregilsson/beanstalk-deploy@v20
        with:
          aws_access_key: ${{ secrets.AWS_ACCESS_KEY_ID }}
          aws_secret_key: ${{ secrets.AWS_SECRET_ACCESS_KEY }}
          application_name: github-action
          environment_name: github-action-front-env
          version_label: github-action-${{ steps.current-time.outputs.formattedTime }}
          region: ap-northeast-2
          deployment_package: ./deploy.zip
